{
  "name": "cloze-mcp",
  "version": "1.0.0",
  "description": "MCP server implementation for Cloze CRM",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --loader ts-node/esm src/test-runner/index.ts",
    "test:error": "node --loader ts-node/esm src/test-runner/workflows/error_handling.js",
    "lint": "tsc --noEmit",
    "test:mcp": "node src/test-client/comprehensive-test.js",
    "test:schema": "node src/test-client/schema-test-esm.js",
    "verify:schemas": "node src/test-client/verify-schemas-enhanced.js",
    "test:unit": "jest",
    "tools:standardize": "node src/tools/templates/standardize-all-tools.js",
    "tools:standardize-one": "node src/tools/templates/standardize-tool.js",
    "validate:example": "node src/test-client/client-schema-validation.js",
    "test:simple-schema": "node src/test-client/simple-schema-test.js",
    "test:mcp-format": "node src/test-client/verify-schema-mcp-format.js",
    "test:mcp-format:quick": "QUICK_TEST=true node src/test-client/verify-schema-mcp-format.js",
    "test:param-format": "node --loader ts-node/esm src/test-runner/param_tester.ts",
    "test:all-formats": "node --loader ts-node/esm src/test-runner/test-all-formats.ts",
    "test:parameter-formats": "DEBUG_PARAMS=true node src/test-client/parameter-format-test.js"
  },
  "keywords": [
    "cloze",
    "crm",
    "mcp",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.9.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
{
  "name": "cloze",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:force": "node build-ignore-errors.js", /* Legacy command, no longer needed as TypeScript errors are fixed */
    "start": "npm run build && node dist/index.js",
    "dev": "tsc --watch & nodemon dist/index.js",
    "dev:http": "tsc --watch & nodemon dist/server/http-server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npm run lint && npm run format:check",
    "fix": "npm run lint:fix && npm run format",
    "test": "npm run build && node test-consolidated.js",
    "test:workflow": "npm run build && node test-consolidated.js",
    "test:cleanup": "npx tsx src/scripts/cleanup-legacy-tests.ts",
    "test:basic": "npm run test workflows/person-basic-updated.json",
    "test:person": "npm run test workflows/person-tools-complete.json",
    "test:company": "npm run test workflows/company-basic-updated.json",
    "test:multi": "npm run test workflows/multi-step-updated.json",
    "clean": "rm -rf dist",
    "clean:logs": "node ./tests/scripts/cleanup-logs.js --keep 10",
    "clean:logs:all": "node ./tests/scripts/cleanup-logs.js --all",
    "swagger:lookup": "ts-node src/scripts/swagger-lookup.ts",
    "swagger:split": "ts-node src/scripts/swagger-splitter.ts",
    "swagger:validate": "ts-node src/scripts/validate-swagger.ts",
    "swagger:endpoints": "ts-node src/scripts/swagger-lookup.ts endpoints",
    "swagger:tags": "ts-node src/scripts/swagger-lookup.ts tags",
    "swagger:search": "ts-node src/scripts/swagger-lookup.ts search"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.1",
    "axios": "^1.9.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.19.2",
    "fastmcp": "^1.25.0",
    "node-fetch": "^3.3.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
